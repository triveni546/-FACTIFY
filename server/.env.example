PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/factify
JWT_SECRET=your_jwt_secret_here
GEMINI_API_KEY=

# Gmail SMTP (required for email alerts, 2FA OTP, login alerts)
SMTP_EMAIL=your.email@gmail.com
SMTP_APP_PASSWORD=your_gmail_app_password

# Contact form + alerts (Gmail SMTP — must be App Password, not normal password)
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=16charapppasswordhere
# Optional: use port 587 if 465 is blocked
# SMTP_PORT=587
